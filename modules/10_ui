function imagenSegura(img, nombreBanda, aoi) {
  if (img) {
    return ee.Image(img)
      .rename(nombreBanda)
      .clip(aoi);
  }

  print('Advertencia: capa faltante en UI. Se usará imagen 0:', nombreBanda);

  return ee.Image.constant(0)
    .rename(nombreBanda)
    .clip(aoi);
}

