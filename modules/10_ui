    try {
      Map.unlisten(clickListenerIdGlobal);
    } catch (err) {
      print('Advertencia: no se pudo remover listener anterior del mapa:', err);
    }

    clickListenerIdGlobal = null;
  }

  clickListenerIdGlobal = Map.onClick(function(coords) {
    // Si existe un listener antiguo, se ignora.
    if (clickVersionLocal !== clickVersionGlobal) {
      return;
    }

    var punto = ee.Geometry.Point([
      coords.lon,
      coords.lat
    ]);

    var valores = imagenResumen.reduceRegion({
      reducer: ee.Reducer.first(),
      geometry: punto,
      scale: app.escala,
      maxPixels: 1e13,
      bestEffort: true
    });

    valores.evaluate(function(v) {
      if (!v) {
        inspector.setValue('Sin datos en este punto.');
        return;
      }

      var lineas = [
        'Lon: ' + coords.lon.toFixed(5),
        'Lat: ' + coords.lat.toFixed(5)
      ];

      Object.keys(v).sort().forEach(function(k) {
        lineas.push(k + ': ' + formatoValor(v[k]));
      });

      inspector.setValue(lineas.join('\n'));
    });
  });

  // ===============================
  // LEYENDA
  // ===============================
  var leyenda = ui.Panel({
    style: {
      position: 'bottom-left',
      padding: '8px',
      backgroundColor: 'rgba(255,255,255,0.9)'
    }
  });

