    value: 'Semáforo ganadero',
    style: {
      fontWeight: 'bold'
    }
  }));

  leyenda.add(crearFilaLeyenda('red', '1 - Crítico'));
  leyenda.add(crearFilaLeyenda('yellow', '2 - Precaución'));
  leyenda.add(crearFilaLeyenda('green', '3 - Favorable'));

  Map.add(leyenda);

  // =======================================================
  // CONFIGURAR PANELES OCULTABLES
  // =======================================================
  configurarPanelesOcultables(panelIzquierdo, panelDerecho);

  // ===============================
  // AGREGAR PANELES
  // ===============================
  if (!panelIzquierdoInsertado) {
    ui.root.insert(0, panelIzquierdo);
    panelIzquierdoInsertado = true;
  }

  Map.add(panelDerecho);
}

