    label: 'Dibujar finca en el mapa',
    style: {
      stretch: 'horizontal'
    },
    onClick: function() {
      prepararDibujoPoligono();

      estado.setValue(
        'Dibuja el polígono de la finca y luego presiona "Actualizar análisis".'
      );

      estado.style().set('color', 'blue');
    }
  });

  var botonLimpiarDibujo = ui.Button({
    label: 'Limpiar dibujo',
    style: {
      stretch: 'horizontal'
    },
    onClick: function() {
      limpiarDibujos();

      estado.setValue(
        'Dibujo eliminado.\nPuedes dibujar otro polígono.'
      );

      estado.style().set('color', 'gray');
    }
  });

  var botonActualizar = ui.Button({
    label: 'Actualizar análisis',
    style: {
      stretch: 'horizontal',
      color: 'red',
      backgroundColor: 'white',
      fontWeight: 'bold',
      margin: '8px 0 8px 0'
    },
    onClick: function() {
      var nuevaFechaInicio = fechaInicioBox.getValue();
      var nuevaFechaFinal = fechaFinalBox.getValue();

      if (!validarFecha(nuevaFechaInicio) || !validarFecha(nuevaFechaFinal)) {
        estado.setValue('Error: usa fechas válidas con formato YYYY-MM-DD.');
        estado.style().set('color', 'red');
        return;
      }

      if (!fechaFinalMayorIgual(nuevaFechaInicio, nuevaFechaFinal)) {
        estado.setValue('Error: la fecha final debe ser igual o posterior a la fecha inicial.');
        estado.style().set('color', 'red');
        return;
      }

      var nuevoAOI = null;
      var origenAOI = '';

      var textoAOI = aoiBox.getValue();

      // ---------------------------------------------------
      // 1. AOI desde cajetín
      // ---------------------------------------------------
      if (textoAOI && textoAOI.trim() !== '') {
        try {
          nuevoAOI = obtenerAOIDesdeTexto(textoAOI);
          origenAOI = 'AOI cargado desde cajetín';
        } catch (err) {
          estado.setValue('Error leyendo AOI. Revisa coordenadas o ruta de asset.');
          estado.style().set('color', 'red');
          print('Error AOI cajetín:', err);
          return;
        }
      }

      // ---------------------------------------------------
      // 2. AOI dibujado en mapa
      // ---------------------------------------------------
      if (!nuevoAOI) {
        nuevoAOI = obtenerAOIDibujado();

        if (nuevoAOI) {
          origenAOI = 'AOI dibujado en el mapa';
        }
      }

      // ---------------------------------------------------
      // 3. Si no se ingresó AOI nuevo, usar AOI actual
      // ---------------------------------------------------
      if (!nuevoAOI) {
        nuevoAOI = app.aoi;
        origenAOI = 'AOI actual previamente cargado';
      }

      if (!app.onActualizar) {
        estado.setValue('Error: main.js no envió la función onActualizar.');
        estado.style().set('color', 'red');
        return;
      }

      var areaNuevaHa = nuevoAOI.area(1).divide(10000);
      var areaNuevaKm2 = areaNuevaHa.divide(100);

      estado.setValue(
        'Actualizando análisis...\n' +
        'Inicio: ' + nuevaFechaInicio + '\n' +
        'Final: ' + nuevaFechaFinal + '\n' +
        origenAOI
      );

      estado.style().set('color', 'green');

      print('--------------------------------------');
      print('ACTUALIZAR ANÁLISIS PRESIONADO');
      print('Fecha inicio seleccionada:', nuevaFechaInicio);
      print('Fecha final seleccionada:', nuevaFechaFinal);
      print('Origen AOI:', origenAOI);
      print('AOI usado:', nuevoAOI);
      print('Área AOI ha:', areaNuevaHa);
      print('Área AOI km²:', areaNuevaKm2);
      print('--------------------------------------');

      limpiarDibujos();

      app.onActualizar({
        aoi: nuevoAOI,
        fechaInicio: nuevaFechaInicio,
        fechaFinal: nuevaFechaFinal
      });
    }
  });

  panel.add(botonDibujar);
  panel.add(botonLimpiarDibujo);
  panel.add(botonActualizar);

  panel.add(ui.Label({
    value:
      'Nota: al actualizar, el polígono usado aparecerá como capa "AOI_Finca" ' +
      'en el control de capas, apagada por defecto.',
    style: {
      fontSize: '11px',
      color: 'gray',
      margin: '6px 0 10px 0'
    }
  }));
}

